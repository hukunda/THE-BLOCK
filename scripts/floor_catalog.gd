static func _w(rows: Array) -> PackedStringArray:
	var out: PackedStringArray = PackedStringArray()
	for s in rows:
		var line: String = str(s)
		if line.length() < WIDTH:
			for _i in range(WIDTH - line.length()):
				line += "."
		elif line.length() > WIDTH:
			line = line.substr(0, WIDTH)
		out.append(line)
	return out
