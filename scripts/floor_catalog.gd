class_name FloorCatalog
## All ten floors — maps, boss ids, tone (GAME_DESIGN.md §8–9).

const WIDTH: int = 32


static func floor_count() -> int:
	return 10


static func get_bundle(index_zero_based: int) -> Dictionary:
	match index_zero_based:
		0:
			return _pack(
				"THE LOBBY",
				"doorman",
				"Slow feet. A desk that never helped anyone.",
				_f1_map(),
				0.0
			)
		1:
			return _pack(
				"THE STAIRWELL",
				"fall",
				"Vertical. Unforgiving. Someone oil these steps in hell.",
				_f2_map(),
				0.0
			)
		2:
			return _pack(
				"THE VIDEO STORE",
				"late_fee",
				"Shelves of dead formats. Deadlines that outlived customers.",
				_f3_map(),
				0.05
			)
		3:
			return _pack(
				"THE ARCADE",
				"player_one",
				"Lights that lie. High scores nobody earned honestly.",
				_f4_map(),
				0.08
			)
		4:
			return _pack(
				"COMPUTER ROOMS",
				"modem",
				"Handshakes you can hear. Patience you do not have.",
				_f5_map(),
				0.18
			)
		5:
			return _pack(
				"THE SLEEPERS",
				"remembers",
				"Warmth borrowed from infrastructure. Dreams on layaway.",
				_f6_map(),
				0.06
			)
		6:
			return _pack(
				"NETWORK FLOOR",
				"ping",
				"Packets pretending to be places. You are lagging behind yourself.",
				_f7_map(),
				0.22
			)
		7:
			return _pack(
				"EMPTY APARTMENTS",
				"tenant",
				"Absence with furniture. Reflections with appetite.",
				_f8_map(),
				0.1
			)
		8:
			return _pack(
				"THE ELEVATOR",
				"caretaker",
				"A box that negotiates gravity and regret.",
				_f9_map(),
				0.12
			)
		9:
			return _pack(
				"THE ROOF",
				"the_block",
				"No more upstairs. Only weather and procedure.",
				_f10_map(),
				0.28
			)
		_:
			return get_bundle(0)


static func _pack(title: String, boss_id: String, blurb: String, rows: PackedStringArray, glitch: float) -> Dictionary:
	return {
		"title": title,
		"boss_id": boss_id,
		"blurb": blurb,
		"map": rows,
		"glitch": glitch,
	}


